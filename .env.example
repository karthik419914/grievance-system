# FIREBASE_PROJECT_ID=grivence-system-a6583
# FIREBASE_CLIENT_EMAIL=your-service-account-email@grivence-system-a6583.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

